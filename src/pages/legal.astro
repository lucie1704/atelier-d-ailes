---
import MarkdownLayout from '~/layouts/MarkdownLayout.astro';
import { useTranslations } from '~/utils/i18n';
import { FULLNAME, ADDRESS, PHONE } from '../constants/contact';
import { SITE } from 'astrowind:config';

const { t } = useTranslations(Astro.currentLocale);

const frontmatter = {
  title: t('legal.frontmatter.title'),
  tagline: t('legal.frontmatter.tagline'),
  subtitle: t('legal.frontmatter.subtitle'),
};
---

<MarkdownLayout
  frontmatter={frontmatter}
  content={t('legal.content', {
    fullName: FULLNAME,
    siteName: SITE.name,
    address: ADDRESS,
    phone: PHONE.FORMAT_INTL ?? '',
  })}
/>
