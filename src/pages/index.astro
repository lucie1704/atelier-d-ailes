---
import Layout from '~/layouts/PageLayout.astro';
import HeroBanner from '~/components/widgets/HeroBanner.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Content from '~/components/widgets/Content.astro';
import Markdown from '~/components/ui/Markdown.astro';
import { CREATION_DATE } from '~/constants/shop';
import { SITE } from 'astrowind:config';
import { useTranslations } from '~/utils/i18n';
import { FULLNAME } from '~/constants/contact';

// Images
import heroImage from '~/assets/images/atelier-hero-image.png';
import paracheckImage from '~/assets/images/paracheck.png';
import christopheImage from '~/assets/images/christophe-profile-1.png';

const { t, tr } = useTranslations(Astro.currentLocale);

const metadata = {
  title: `${SITE.name} — ${t('home.meta.title')}`,
  description: t('home.meta.description'),
  ignoreTitleTemplate: true,
};

const yearsSinceCreation = (() => {
  const today = new Date();
  let years = today.getFullYear() - CREATION_DATE.getFullYear();

  const hasPassedAnniversary =
    today.getMonth() > CREATION_DATE.getMonth() ||
    (today.getMonth() === CREATION_DATE.getMonth() && today.getDate() >= CREATION_DATE.getDate());

  if (!hasPassedAnniversary) {
    years -= 1;
  }

  return years;
})();
---

<Layout metadata={metadata} ctaBanner>
  <HeroBanner
    id="atelier-banner"
    title={SITE.name}
    subtitle={t('home.banner.baseline')}
    image={{
      src: heroImage,
      alt: t('home.banner.heroImage.alt'),
    }}
    actions={[
      {
        text: t('home.banner.actions.contact'),
        href: '/contact',
      },
      {
        text: t('home.banner.actions.services'),
        href: '/services',
        variant: 'link',
      },
    ]}
  />

  <Features2
    id="services"
    title={t('home.services.title')}
    subtitle={t('home.services.subtitle')}
    items={[
      {
        title: t('home.services.items.maintenance.title'),
        description: t('home.services.items.maintenance.description'),
        icon: 'lucide:clipboard-check',
      },
      {
        title: t('home.services.items.repair.title'),
        description: t('home.services.items.repair.description'),
        icon: 'lucide:wrench',
      },
      {
        title: t('home.services.items.parachutePacking.title'),
        description: t('home.services.items.parachutePacking.description'),
        icon: 'lucide:shield-check',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-slate-50"></div>
    </Fragment>
  </Features2>

  <Content
    id="christophe-godard"
    columns={2}
    isReversed
    image={{
      src: christopheImage,
      alt: 'Photo de profil de Christophe Godard',
      class: 'rounded-full mx-auto bg-gray-500 shadow-lg',
    }}
  >
    <Fragment slot="content">
      <div class="order-1 md:order-2">
        <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
          {FULLNAME}
        </h2>

        <h3 class="text-xl tracking-tight dark:text-white mb-4">
          {t('home.profile.position')}
        </h3>

        <p>
          « {t('home.profile.quote', { yearsSinceCreation })} »
        </p>
      </div>
    </Fragment>
  </Content>

  <Steps
    id="experience"
    title={t('home.experience.title')}
    items={[
      {
        title: t('home.experience.items.atelier.title'),
        subtitle: t('home.experience.items.atelier.role'),
        lead: t('home.experience.items.atelier.period'),
        description: t('home.experience.items.atelier.description'),
        icon: 'lucide:wrench',
      },
      {
        title: t('home.experience.items.vld.title'),
        subtitle: t('home.experience.items.vld.role'),
        lead: t('home.experience.items.vld.period'),
        description: t('home.experience.items.vld.description'),
        icon: 'lucide:history',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-slate-50"></div>
    </Fragment>
  </Steps>

  <Content
    id="paracheck"
    items={[
      {
        title: t('home.paracheck.items.maintenance.title'),
        description: t('home.paracheck.items.maintenance.description'),
        icon: 'tabler:certificate',
      },
      {
        title: t('home.paracheck.items.security.title'),
        description: t('home.paracheck.items.security.description'),
        icon: 'tabler:shield-check',
      },
    ]}
    image={{
      src: paracheckImage,
      alt: t('home.paracheck.image.alt'),
      width: 300,
      class: 'mt-10 object-contain mx-auto',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">{t('home.paracheck.title')}</h3>
      <Markdown class="text-lg text-muted mt-2" content={t('home.paracheck.description')} />
    </Fragment>
  </Content>

  <Testimonials
    id="reviews"
    title={t('home.reviews.title')}
    testimonials={tr<Array<{ quote: string; name: string }>>('home.reviews.testimonials').map(({ quote, name }) => ({
      testimonial: quote,
      name,
    }))}
    callToAction={{
      target: '_blank',
      text: t('home.reviews.action'),
      href: 'https://g.page/r/CXJR0tHMRI5OEBM/review',
      icon: 'lucide:chevron-right',
    }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-slate-50"></div>
    </Fragment>
  </Testimonials>
</Layout>
