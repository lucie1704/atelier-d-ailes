---
import { Icon } from 'astro-icon/components';
import { getLocale, getSwitcherData } from 'i18n:astro';

const locale = getLocale();
const switcherData = getSwitcherData();

const flags: Record<string, string> = {
  fr: '🇫🇷',
  en: '🇬🇧',
};
---

<details class="relative inline-block text-[0.9375rem]">
  <summary class="flex items-center gap-2 cursor-pointer py-2 px-4 list-none">
    <span>{flags[locale]}</span>
    <span>{locale.toUpperCase()}</span>
    <Icon name="lucide:chevron-down" class="w-4 h-4 transition-transform duration-200 [[open]_&]:rotate-180" />
  </summary>

  <div
    class="absolute right-0 mr-3 bg-white rounded-lg shadow-lg bottom-full mb-2 md:bottom-auto md:top-full md:mt-2 md:mb-0"
  >
    {
      switcherData.map((option) => (
        <a
          href={option.href}
          class={`flex items-center gap-2 px-4 py-2 ${option.locale === locale ? 'bg-gray-100 rounded-md' : ''}`}
        >
          <span>{flags[option.locale]}</span>
          <span>{option.locale.toUpperCase()}</span>
        </a>
      ))
    }
  </div>
</details>
